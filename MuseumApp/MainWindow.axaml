<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:domain="using:MuseumApp.Domain"
        x:Class="MuseumApp.MainWindow"
        Title="Система керування музеєм" Width="1000" Height="600"
        WindowStartupLocation="CenterScreen"
        x:DataType="domain:MuseumData">

    <Grid RowDefinitions="Auto, *">
        <StackPanel Grid.Row="0" Margin="10" Spacing="10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox Name="InvNumInput" Width="100" PlaceholderText="Інв. №"/>
                <TextBox Name="TitleInput" Width="150" PlaceholderText="Назва"/>
                <TextBox Name="AuthorInput" Width="150" PlaceholderText="Автор/Епоха"/>
                <ComboBox Name="CategoryCombo" Width="130" PlaceholderText="Категорія"/>
                <Button Content="Додати" Click="AddBtn_Click" Background="#4CAF50" Foreground="White"/>
                <Button Content="Перемістити" Click="MoveBtn_Click" Background="#2196F3" Foreground="White"/>
                <Button Content="Списати" Click="DeleteBtn_Click" Background="#F44336" Foreground="White"/>
            </StackPanel>
            
            <Separator/>
            
            <StackPanel Orientation="Horizontal" Spacing="10">
                <TextBox Name="SearchInput" Width="200" PlaceholderText="Пошук за назвою чи №..." TextChanged="OnSearchTextChanged"/>
                <ComboBox Name="FilterCategoryCombo" Width="180" PlaceholderText="Фільтр за категорією" SelectionChanged="OnFilterSelectionChanged"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1" ColumnDefinitions="280, *" Margin="10">
            <Border Grid.Column="0" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5">
                <Grid RowDefinitions="Auto, *, Auto">
                    <TextBlock Grid.Row="0" Text="Зали та Сховища" FontWeight="Bold" Margin="10" FontSize="16"/>
                    <ListBox Grid.Row="1" Name="HallsList" SelectionChanged="HallsList_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="domain:ExhibitionHall">
                                <TextBlock Text="{Binding Name}" Padding="5"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    
                    <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="#EEEEEE" Padding="5">
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBox Name="NewHallInput" Width="130" PlaceholderText="Назва залу"/>
                            <Button Content="+" Click="AddHallBtn_Click" Background="#FF9800" Foreground="White" Width="35" HorizontalContentAlignment="Center"/>
                            <Button Content="🗑" Click="DeleteHallBtn_Click" Background="#F44336" Foreground="White" Width="35" HorizontalContentAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="1" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Margin="10,0,0,0">
                <Grid RowDefinitions="Auto, *">
                    <Grid Grid.Row="0" ColumnDefinitions="90, 200, 150, 100, 120" Margin="15,5,5,5">
                        <TextBlock Grid.Column="0" Text="№" FontWeight="Bold" Foreground="Gray"/>
                        <TextBlock Grid.Column="1" Text="Назва" FontWeight="Bold" Foreground="Gray"/>
                        <TextBlock Grid.Column="2" Text="Автор/Епоха" FontWeight="Bold" Foreground="Gray"/>
                        <TextBlock Grid.Column="3" Text="Тип" FontWeight="Bold" Foreground="Gray"/>
                        <TextBlock Grid.Column="4" Text="Статус" FontWeight="Bold" Foreground="Gray" TextAlignment="Right"/>
                    </Grid>
                    <ListBox Grid.Row="1" Name="ExhibitsList" Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="domain:Exhibit">
                                <Grid ColumnDefinitions="90, 200, 150, 100, 120" Margin="0,2">
                                    <TextBlock Grid.Column="0" Text="{Binding InventoryNumber}" FontWeight="Bold" Foreground="#1565C0"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" TextWrapping="Wrap"/>
                                    <TextBlock Grid.Column="2" Text="{Binding AuthorOrEra}" Foreground="#666666"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Category}"/>
                                    <TextBlock Grid.Column="4" Text="{Binding Status}" FontStyle="Italic" TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>